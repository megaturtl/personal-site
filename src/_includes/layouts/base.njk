{# Base template for all normal pages to use #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ description | default('My website') }}">
    <title>{% if title %}{{ title }} - {% endif %}{{ site.name }}</title>
    
    <!-- Global variables (sizing, typography) -->
    <link rel="stylesheet" href="/assets/css/vars.css">
    <!-- Base styles (layout, etc) -->
    <link rel="stylesheet" href="/assets/css/base.css">
    <!-- Component styles -->
    <link rel="stylesheet" href="/assets/css/components/header.css">
    <link rel="stylesheet" href="/assets/css/components/footer.css">
    <!-- Theme styles (colors only) -->
    <link rel="stylesheet" href="/assets/css/themes/light.css">
    <link rel="stylesheet" href="/assets/css/themes/dark.css">
    <link rel="stylesheet" href="/assets/css/themes/candy.css">
    <!-- Page-specific styles -->
    {% if pageCSS %}
    <link rel="stylesheet" href="/assets/css/pages/{{ pageCSS }}.css">
    {% endif %}
</head>
<body>
    {% include "components/header.njk" %}

    <main>
        {{ content | safe }}
    </main>

    {% include "components/footer.njk" %}

    <!-- Scripts -->
    <script src="/assets/js/theme-toggle.js" defer></script>
</body>
</html> 